{
  "name": "EO3",
  "description": "formats ao3 html downloads for printing",
  "version": "1.0",
  "manifest_version": 3,
  "icons": {
    "16": "./images/eo3-16.png",
    "32": "./images/eo3-32.png",
    "48": "./images/eo3-48.png",
    "128": "./images/eo3-128.png"
  },
  "action": {
    "default_popup": "popup/popup.html"
  },
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://download.archiveofourown.org/*"
  ]
}